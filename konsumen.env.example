# Contoh env untuk backend Konsumen. Di server, salin ke /opt/apps/konsumen.env
# lalu sesuaikan. deploy.sh memuat file ini sebelum (re)start PM2.

# Port HTTP (nginx mem-proxy /be/konsumen -> port ini).
KONSUMEN_PORT=8092

# PostgreSQL (DB greenpark bersama).
KONSUMEN_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5434/greenpark?sslmode=disable

# SSO staf (Sales & divisi) — JWKS master auth service.
AUTH_JWKS_URL=http://127.0.0.1:8090/.well-known/jwks.json

# Relasi ke backend Sales (impor prospek dari Konsumen Screening).
SALES_API_BASE=http://127.0.0.1:8085

# Folder simpan berkas/lampiran. Pakai path PERSISTEN di luar folder repo agar
# tidak hilang saat re-clone (folder repo default: ./uploads).
KONSUMEN_UPLOAD_DIR=/opt/apps/konsumen-uploads

# CORS: kosongkan/`*` bila fe satu origin lewat nginx; atau isi origin fe.
KONSUMEN_ALLOW_ORIGIN=*
